{
  "name": "@hardpointlabs/sdk",
  "version": "1.0.10",
  "description": "Hardpoint SDK",
  "repository": {
    "type": "git",
    "url": "https://github.com/hardpointlabs/sdk"
  },
  "license": "Apache-2.0",
  "author": "Hardpoint Labs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "directories": {
    "src": "src",
    "dist": "dist",
    "test": "test"
  },
  "scripts": {
    "build": "npx tsc && cp ./lib/ca.crt ./dist/ && npx typedoc --out ./dist/docs && node scripts/run-fta.js . --config-path ./fta.json",
    "docs": "npx typedoc --out ./dist/docs",
    "lint": "eslint src/",
    "test": "echo \"Error: no test specified\" && exit 1",
    "integration-test": "npm run integration-test:node",
    "integration-test:node": "tsc -p integration/tsconfig.json --outDir integration && node integration/test.js",
    "integration-test:deno": "deno run --allow-all --check integration/test.ts",
    "integration-test:bun": "bun run integration/test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.57.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "fta-cli": "^3.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "wrangler": "^4.84.1"
  },
  "dependencies": {
    "@hardpointlabs/length-prefixed-stream": "^2.0.6",
    "mlkem": "^2.7.0"
  },
  "bugs": {
    "url": "https://github.com/hardpointlabs/sdk/issues"
  },
  "homepage": "https://github.com/hardpointlabs/sdk",
  "release": {
    "branches": [
      "master"
    ]
  }
}
